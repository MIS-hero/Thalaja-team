# ═══════════════════════════════════════════════════
# Thalaja API - Environment Variables Template
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════

# ── Flask Core ──
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-secret-string

# ── Database (Supabase PostgreSQL) ──
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ── Supabase Auth (GoTrue) ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── JWT Configuration ──
JWT_SECRET_KEY=change-me-to-another-random-string
JWT_ALGORITHM=RS256

# ── OTP / Notification Channels (US-36) ──
# Order of fallback: sms -> whatsapp -> email
OTP_ORDER=sms,whatsapp,email

# ── SMS Provider (e.g., Twilio) ──
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890

# ── WhatsApp (Mock for now) ──
WHATSAPP_MOCK=true