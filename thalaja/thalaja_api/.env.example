# ── Flask ────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=replace-with-a-long-random-string

# ── Supabase Postgres (SQLAlchemy) ───────────────────────
# Settings → Database → Connection string → URI (use the 6543 pooler)
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Supabase Auth / API (identity + sessions/JWT only) ───
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_KEY=<service-role-key>          # keep server-side only
SUPABASE_JWT_SECRET=<jwt-secret-from-api-settings>
SUPABASE_JWT_AUDIENCE=authenticated

# ── Authentica (OTP provider for US-36) ──────────────────
AUTHENTICA_BASE_URL=https://api.authentica.sa
AUTHENTICA_API_KEY=$2y$10$Dsa2/WREcRBDvsuzZoMYm.OXqoybxrHbU6Ulps.g7Gj9qnSIlv.aq
AUTHENTICA_OTP_METHOD=whatsapp
AUTHENTICA_TEMPLATE_ID=11
AUTHENTICA_FALLBACK_EMAIL=zaytona.team@gmail.com
