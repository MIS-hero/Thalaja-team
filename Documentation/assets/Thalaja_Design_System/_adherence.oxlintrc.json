{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/patterns/**",
              "ui_kits/thalaja-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:CooperArabic|Baloo 2|Tajawal))/i]",
        "message": "Font not provided by the design system. Available: CooperArabic, Baloo 2, Tajawal."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|shape|colorIndex|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, shape, colorIndex."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|blob)$/]",
        "message": "<Avatar> shape must be one of 'circle' | 'blob'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|size|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, size, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|red|mint|indigo|lilac|navy)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'red' | 'mint' | 'indigo' | 'lilac' | 'navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Blob'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|tone|halo|haloWidth|rotate|children|key|ref|className|style|children)$/]",
        "message": "<Blob> doesn't accept that prop. Declared props: size, tone, halo, haloWidth, rotate, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|block|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, block, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|mint|ghost|outline|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'mint' | 'ghost' | 'outline' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|tone|padding|radius|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, tone, padding, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|pop|sunken|brand)$/]",
        "message": "<Card> variant must be one of 'plain' | 'pop' | 'sunken' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:red|mint|indigo|lilac)$/]",
        "message": "<Card> tone must be one of 'red' | 'mint' | 'indigo' | 'lilac'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|selected|tone|key|ref|className|style|children)$/]",
        "message": "<CategoryChip> doesn't accept that prop. Declared props: label, icon, selected, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:indigo|red|mint|lilac)$/]",
        "message": "<CategoryChip> tone must be one of 'indigo' | 'red' | 'mint' | 'lilac'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|size|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, size, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='GroceryItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|note|checked|onToggle|category|categoryTone|addedBy|trailing|dir|key|ref|className|style|children)$/]",
        "message": "<GroceryItem> doesn't accept that prop. Declared props: name, note, checked, onToggle, category, categoryTone, addedBy, trailing, dir."
      },
      {
        "selector": "JSXOpeningElement[name.name='GroceryItem'] > JSXAttribute[name.name='categoryTone'] > Literal[value!=/^(?:red|mint|indigo|lilac)$/]",
        "message": "<GroceryItem> categoryTone must be one of 'red' | 'mint' | 'indigo' | 'lilac'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GroceryItem'] > JSXAttribute[name.name='dir'] > Literal[value!=/^(?:rtl|ltr)$/]",
        "message": "<GroceryItem> dir must be one of 'rtl' | 'ltr'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|shape|tone|ariaLabel|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, variant, size, shape, tone, ariaLabel, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|ghost|outline)$/]",
        "message": "<IconButton> variant must be one of 'soft' | 'solid' | 'ghost' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|rounded)$/]",
        "message": "<IconButton> shape must be one of 'circle' | 'rounded'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:indigo|red|mint|navy)$/]",
        "message": "<IconButton> tone must be one of 'indigo' | 'red' | 'mint' | 'navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|label|hint|error|iconLeft|iconRight|dir|disabled|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, label, hint, error, iconLeft, iconRight, dir, disabled, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='dir'] > Literal[value!=/^(?:rtl|ltr)$/]",
        "message": "<Input> dir must be one of 'rtl' | 'ltr'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListSummaryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|household|members|total|done|accent|onClick|key|ref|className|style|children)$/]",
        "message": "<ListSummaryCard> doesn't accept that prop. Declared props: title, household, members, total, done, accent, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListSummaryCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:red|indigo|mint|lilac)$/]",
        "message": "<ListSummaryCard> accent must be one of 'red' | 'indigo' | 'mint' | 'lilac'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QtyStepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|min|max|unit|size|disabled|key|ref|className|style|children)$/]",
        "message": "<QtyStepper> doesn't accept that prop. Declared props: value, onChange, min, max, unit, size, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='QtyStepper'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<QtyStepper> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|badge|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, badge."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
